<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_background"
    android:gravity="center">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_campfire"
            android:contentDescription="@string/campfire_logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/campsite_commander"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/splash_text"
            android:layout_marginTop="20dp"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/your_adventure_inventory_manager"
            android:textSize="14sp"
            android:textColor="@color/splash_subtitle"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</RelativeLayout>